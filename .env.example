# ============================================================
# Diese Werte traegst du spaeter in Vercel ein
# (Settings -> Environment Variables), NICHT in eine Datei.
# Diese Liste ist nur die Vorlage.
# ============================================================

# --- Frontend (mit VITE_ Praefix = sichtbar im Browser, ist ok) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_REDIRECT_URI=https://DEIN-PROJEKT.vercel.app

# Discord Webhook-URLs (Posten aus dem Browser, wie im Tracker)
VITE_WEBHOOK_TICKETS=
VITE_WEBHOOK_ARCHIVE=

# --- Server (OHNE VITE_ = nur fuer die /api Login-Funktion, geheim) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_MOD_ROLE_ID=
# Firebase Service-Account JSON als EINE Zeile (aus Firebase-Console)
FIREBASE_SERVICE_ACCOUNT=
